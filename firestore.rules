rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Role lives in users/{uid}, written only from the Firebase console —
    // a client can never grant itself a role.
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasProfile() && profile().data.role == 'admin';
    }

    function isStaff() {
      return hasProfile() && profile().data.role in ['admin', 'staff'];
    }

    match /users/{userId} {
      // users may read their own profile; admin may read all
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      // admin manages staff accounts from the app, but can never touch their
      // own profile doc — no accidental self-demotion or lockout
      allow create, update, delete: if isAdmin() && request.auth.uid != userId;
      // anyone may rename themselves — strictly the name field; role and
      // route allocations on your own doc stay locked
      allow update: if hasProfile() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
        && request.resource.data.name is string;
    }

    match /customers/{customerId} {
      // staff need balances for the collection sheet; only admin mutates
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /ledgerEntries/{entryId} {
      allow read: if isStaff();
      // staff record received payments (credits) only; admin does everything
      allow create: if isAdmin() || (isStaff() && request.resource.data.type == 'credit');
      allow update, delete: if isAdmin();
    }

    // collection routes customers are assigned to
    match /routes/{routeId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // banks / UPI handles payments land in; staff read them to pick a mode
    match /paymentAccounts/{accountId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // known district/city names, persisted independently of customer records
    match /meta/locations {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // app-wide preferences: date format, landing page
    match /meta/preferences {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // CSV bulk-entry audit log — admin-only; never deleted, only marked reversed
    match /importBatches/{batchId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
